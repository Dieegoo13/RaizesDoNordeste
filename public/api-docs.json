{
    "openapi": "3.0.0",
    "info": {
        "title": "Raízes do Nordeste API",
        "version": "1.0.0",
        "description": "API REST para a rede de lanchonetes Raízes do Nordeste. Suporta múltiplos canais (APP, TOTEM, BALCAO, PICKUP, WEB), controle de estoque por unidade, pagamento via mock e programa de fidelidade."
    },
    "servers": [
        { "url": "http://localhost:8000/api", "description": "Servidor local" }
    ],
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        }
    },
    "paths": {
        "/auth/login": {
            "post": {
                "tags": ["Auth"],
                "summary": "Login do usuário",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": ["email", "password"],
                                "properties": {
                                    "email":    { "type": "string", "example": "admin@raizes.com" },
                                    "password": { "type": "string", "example": "password" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Token JWT retornado" },
                    "401": { "description": "Credenciais inválidas" },
                    "422": { "description": "Dados inválidos" }
                }
            }
        },
        "/usuarios": {
            "post": {
                "tags": ["Auth"],
                "summary": "Cadastro de novo cliente",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": ["name","email","password","consentimentos_lgpd"],
                                "properties": {
                                    "name":                { "type": "string",  "example": "Maria Santos" },
                                    "email":               { "type": "string",  "example": "maria@exemplo.com" },
                                    "password":            { "type": "string",  "example": "Senha@123" },
                                    "consentimentos_lgpd": { "type": "boolean", "example": true }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "Usuário criado" },
                    "409": { "description": "E-mail já cadastrado" },
                    "422": { "description": "Consentimento LGPD obrigatório" }
                }
            }
        },
        "/auth/logout": {
            "post": {
                "tags": ["Auth"],
                "summary": "Logout do usuário",
                "security": [{ "bearerAuth": [] }],
                "responses": {
                    "200": { "description": "Logout realizado" },
                    "401": { "description": "Não autenticado" }
                }
            }
        },
        "/unidades": {
            "get": {
                "tags": ["Unidades"],
                "summary": "Listar unidades ativas",
                "parameters": [
                    { "name": "page",  "in": "query", "schema": { "type": "integer" } },
                    { "name": "limit", "in": "query", "schema": { "type": "integer" } }
                ],
                "responses": { "200": { "description": "Lista de unidades" } }
            }
        },
        "/unidades/{id}": {
            "get": {
                "tags": ["Unidades"],
                "summary": "Detalhar unidade",
                "parameters": [
                    { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
                ],
                "responses": {
                    "200": { "description": "Detalhes da unidade" },
                    "404": { "description": "Não encontrada" }
                }
            }
        },
        "/produtos": {
            "get": {
                "tags": ["Produtos"],
                "summary": "Listar produtos disponíveis por unidade",
                "parameters": [
                    { "name": "unidade_id", "in": "query", "required": true, "schema": { "type": "integer" } },
                    { "name": "page",       "in": "query", "schema": { "type": "integer" } },
                    { "name": "limit",      "in": "query", "schema": { "type": "integer" } }
                ],
                "responses": {
                    "200": { "description": "Cardápio da unidade" },
                    "400": { "description": "unidade_id obrigatório" }
                }
            }
        },
        "/produtos/{id}": {
            "get": {
                "tags": ["Produtos"],
                "summary": "Detalhar produto",
                "parameters": [
                    { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
                ],
                "responses": {
                    "200": { "description": "Produto encontrado" },
                    "404": { "description": "Não encontrado" }
                }
            }
        },
        "/estoque": {
            "get": {
                "tags": ["Estoque"],
                "summary": "Consultar estoque por unidade",
                "security": [{ "bearerAuth": [] }],
                "parameters": [
                    { "name": "unidade_id", "in": "query", "required": true, "schema": { "type": "integer" } }
                ],
                "responses": {
                    "200": { "description": "Saldo de estoque" },
                    "403": { "description": "Sem permissão" }
                }
            }
        },
        "/estoque/movimentacao": {
            "post": {
                "tags": ["Estoque"],
                "summary": "Registrar entrada ou saída de estoque",
                "security": [{ "bearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": ["unidade_id","produto_id","tipo","quantidade"],
                                "properties": {
                                    "unidade_id": { "type": "integer", "example": 1 },
                                    "produto_id": { "type": "integer", "example": 1 },
                                    "tipo":       { "type": "string",  "enum": ["ENTRADA","SAIDA"], "example": "ENTRADA" },
                                    "quantidade": { "type": "integer", "example": 50 }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "Movimentação registrada" },
                    "409": { "description": "Saldo insuficiente" },
                    "422": { "description": "Dados inválidos" }
                }
            }
        },
        "/pedidos": {
            "get": {
                "tags": ["Pedidos"],
                "summary": "Listar pedidos com filtros",
                "security": [{ "bearerAuth": [] }],
                "parameters": [
                    { "name": "canal_pedido", "in": "query", "schema": { "type": "string", "enum": ["APP","TOTEM","BALCAO","PICKUP","WEB"] } },
                    { "name": "status",       "in": "query", "schema": { "type": "string" } },
                    { "name": "unidade_id",   "in": "query", "schema": { "type": "integer" } },
                    { "name": "page",         "in": "query", "schema": { "type": "integer" } }
                ],
                "responses": {
                    "200": { "description": "Lista paginada de pedidos" },
                    "401": { "description": "Não autenticado" },
                    "403": { "description": "Sem permissão" }
                }
            },
            "post": {
                "tags": ["Pedidos"],
                "summary": "Criar novo pedido — fluxo crítico",
                "security": [{ "bearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": ["unidade_id","canal_pedido","itens"],
                                "properties": {
                                    "unidade_id":        { "type": "integer", "example": 1 },
                                    "canal_pedido":      { "type": "string",  "enum": ["APP","TOTEM","BALCAO","PICKUP","WEB"], "example": "TOTEM" },
                                    "forma_pagamento":   { "type": "string",  "example": "MOCK" },
                                    "cenario_pagamento": { "type": "string",  "enum": ["APROVADO","RECUSADO"], "example": "APROVADO" },
                                    "itens": {
                                        "type": "array",
                                        "items": {
                                            "properties": {
                                                "produto_id": { "type": "integer", "example": 1 },
                                                "quantidade": { "type": "integer", "example": 2 }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "Pedido criado com sucesso" },
                    "409": { "description": "Estoque insuficiente" },
                    "422": { "description": "canal_pedido ausente ou inválido" }
                }
            }
        },
        "/pedidos/{id}": {
            "get": {
                "tags": ["Pedidos"],
                "summary": "Detalhar pedido",
                "security": [{ "bearerAuth": [] }],
                "parameters": [
                    { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
                ],
                "responses": {
                    "200": { "description": "Detalhes do pedido" },
                    "403": { "description": "Sem permissão" },
                    "404": { "description": "Não encontrado" }
                }
            }
        },
        "/pedidos/{id}/status": {
            "patch": {
                "tags": ["Pedidos"],
                "summary": "Atualizar status do pedido",
                "security": [{ "bearerAuth": [] }],
                "parameters": [
                    { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": ["status"],
                                "properties": {
                                    "status": { "type": "string", "enum": ["RECEBIDO","EM_PREPARO","PRONTO","ENTREGUE","CANCELADO"] }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Status atualizado" },
                    "400": { "description": "Transição inválida" },
                    "404": { "description": "Não encontrado" }
                }
            }
        },
        "/fidelidade/saldo/{clienteId}": {
            "get": {
                "tags": ["Fidelidade"],
                "summary": "Consultar saldo de pontos",
                "security": [{ "bearerAuth": [] }],
                "parameters": [
                    { "name": "clienteId", "in": "path", "required": true, "schema": { "type": "integer" } }
                ],
                "responses": {
                    "200": { "description": "Saldo de pontos" },
                    "403": { "description": "Sem permissão" },
                    "404": { "description": "Usuário não encontrado" }
                }
            }
        },
        "/fidelidade/historico/{clienteId}": {
            "get": {
                "tags": ["Fidelidade"],
                "summary": "Histórico de pontos",
                "security": [{ "bearerAuth": [] }],
                "parameters": [
                    { "name": "clienteId", "in": "path", "required": true, "schema": { "type": "integer" } }
                ],
                "responses": {
                    "200": { "description": "Histórico paginado" },
                    "403": { "description": "Sem permissão" }
                }
            }
        },
        "/fidelidade/resgatar": {
            "post": {
                "tags": ["Fidelidade"],
                "summary": "Resgatar pontos de fidelidade",
                "security": [{ "bearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": ["pontos"],
                                "properties": {
                                    "pontos": { "type": "integer", "example": 100 }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "Pontos resgatados" },
                    "422": { "description": "Saldo insuficiente" }
                }
            }
        }
    }
}