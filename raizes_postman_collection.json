    {
      "name": "ESTOQUE",
      "description": "Controle de estoque por unidade — restrito a ADMIN e GERENTE",
      "item": [
        {
          "name": "T21 - Entrada de estoque (POSITIVO 201)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T21 | Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('T21 | Tem saldo_atual', () => {",
                  "    pm.expect(pm.response.json().saldo_atual).to.be.a('number');",
                  "});",
                  "pm.test('T21 | Tipo ENTRADA', () => {",
                  "    pm.expect(pm.response.json().tipo).to.eql('ENTRADA');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_admin}}" }
            ],
            "url": "{{base_url}}/estoque/movimentacao",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"unidade_id\": 1,\n    \"produto_id\": 1,\n    \"tipo\": \"ENTRADA\",\n    \"quantidade\": 100\n}"
            }
          }
        },
        {
          "name": "T22 - Consultar estoque (POSITIVO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T22 | Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('T22 | Tem data array', () => {",
                  "    pm.expect(pm.response.json().data).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "url": {
              "raw": "{{base_url}}/estoque?unidade_id=1",
              "query": [{ "key": "unidade_id", "value": "1" }]
            }
          }
        },
        {
          "name": "T23 - Estoque sem permissão de cliente (NEGATIVO 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T23 | Status 403', () => pm.response.to.have.status(403));",
