{
  "info": {
    "name": "Raízes do Nordeste API",
    "description": "Coleção completa de testes para o Projeto Multidisciplinar Back-End (UNINTER 2026).\n\nFluxo de execução obrigatório:\n1. Execute a pasta AUTH primeiro (T01, T02, T03) para gerar os tokens\n2. Execute Unidades e Produtos\n3. Execute Pedidos (T08 gera o pedido_id usado nos demais)\n4. Execute Estoque e Fidelidade\n\nVariáveis de ambiente utilizadas:\n- base_url: http://localhost:8000/api\n- token_admin, token_cliente, token_cozinha (gerados automaticamente pelos scripts)\n- pedido_id (gerado automaticamente pelo T08)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",      "value": "http://localhost:8000/api", "type": "string" },
    { "key": "token_admin",   "value": "", "type": "string" },
    { "key": "token_cliente", "value": "", "type": "string" },
    { "key": "token_cozinha", "value": "", "type": "string" },
    { "key": "pedido_id",     "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "AUTH",
      "description": "Autenticação JWT — login, logout e cadastro de usuários",
      "item": [
        {
          "name": "T01 - Login Admin (POSITIVO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T01 | Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('T01 | Tem access_token', () => {",
                  "    const j = pm.response.json();",
                  "    pm.expect(j.access_token).to.be.a('string');",
                  "    pm.collectionVariables.set('token_admin', j.access_token);",
                  "});",
                  "pm.test('T01 | Perfil é ADMIN', () => {",
                  "    pm.expect(pm.response.json().user.profile).to.eql('ADMIN');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@raizes.com\",\n    \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "T02 - Login Cliente (POSITIVO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T02 | Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('T02 | Tem access_token', () => {",
                  "    const j = pm.response.json();",
                  "    pm.expect(j.access_token).to.be.a('string');",
                  "    pm.collectionVariables.set('token_cliente', j.access_token);",
                  "});",
                  "pm.test('T02 | Perfil é CLIENTE', () => {",
                  "    pm.expect(pm.response.json().user.profile).to.eql('CLIENTE');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"cliente@raizes.com\",\n    \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "T03 - Login Cozinha (POSITIVO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T03 | Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('T03 | Token gerado', () => {",
                  "    const j = pm.response.json();",
                  "    pm.expect(j.access_token).to.be.a('string');",
                  "    pm.collectionVariables.set('token_cozinha', j.access_token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"cozinha@raizes.com\",\n    \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "T04 - Login senha errada (NEGATIVO 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T04 | Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('T04 | Erro CREDENCIAIS_INVALIDAS', () => {",
                  "    pm.expect(pm.response.json().error).to.eql('CREDENCIAIS_INVALIDAS');",
                  "});",
                  "pm.test('T04 | Tem timestamp e path', () => {",
                  "    const j = pm.response.json();",
                  "    pm.expect(j.timestamp).to.be.a('string');",
                  "    pm.expect(j.path).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@raizes.com\",\n    \"password\": \"senhaerrada123\"\n}"
            }
          }
        },
        {
          "name": "T05 - Cadastrar cliente com LGPD (POSITIVO 201)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T05 | Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('T05 | Tem id', () => pm.expect(pm.response.json().id).to.be.a('number'));",
                  "pm.test('T05 | Perfil CLIENTE', () => pm.expect(pm.response.json().profile).to.eql('CLIENTE'));",
                  "pm.test('T05 | LGPD true', () => pm.expect(pm.response.json().consentimentos_lgpd).to.be.true);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/usuarios",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"João Nordestino\",\n    \"email\": \"joao.nordestino@teste.com\",\n    \"password\": \"Senha@123\",\n    \"consentimentos_lgpd\": true\n}"
            }
          }
        },
        {
          "name": "T06 - Cadastrar sem consentimento LGPD (NEGATIVO 422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T06 | Status 422', () => pm.response.to.have.status(422));",
                  "pm.test('T06 | Erro VALIDACAO_INVALIDA', () => {",
                  "    pm.expect(pm.response.json().error).to.eql('VALIDACAO_INVALIDA');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/usuarios",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Teste Sem LGPD\",\n    \"email\": \"semconsentimento@teste.com\",\n    \"password\": \"123456\",\n    \"consentimentos_lgpd\": false\n}"
            }
          }
        },
        {
          "name": "T07 - Acesso sem token (NEGATIVO 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T07 | Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('T07 | Sem token retorna erro', () => {",
                  "    pm.expect(pm.response.code).to.equal(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/pedidos"
          }
        }
      ]
    },
