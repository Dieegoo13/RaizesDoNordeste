    {
      "name": "PEDIDOS",
      "description": "Fluxo crítico: criar pedido → pagamento mock → atualizar status",
      "item": [
        {
          "name": "T13 - Criar pedido APROVADO via TOTEM (POSITIVO 201)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T13 | Status 201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.test('T13 | Status RECEBIDO (pagamento aprovado)', () => pm.expect(j.status).to.eql('RECEBIDO'));",
                  "pm.test('T13 | canal_pedido = TOTEM', () => pm.expect(j.canal_pedido).to.eql('TOTEM'));",
                  "pm.test('T13 | Pagamento APROVADO', () => pm.expect(j.pagamento.status).to.eql('APROVADO'));",
                  "pm.test('T13 | Tem transacao_id', () => pm.expect(j.pagamento.transacao_id).to.include('MOCK-TXN'));",
                  "pm.test('T13 | Tem itens', () => pm.expect(j.itens.length).to.be.above(0));",
                  "pm.collectionVariables.set('pedido_id', j.pedido_id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_cliente}}" }
            ],
            "url": "{{base_url}}/pedidos",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"unidade_id\": 1,\n    \"canal_pedido\": \"TOTEM\",\n    \"forma_pagamento\": \"MOCK\",\n    \"cenario_pagamento\": \"APROVADO\",\n    \"itens\": [\n        { \"produto_id\": 1, \"quantidade\": 2 },\n        { \"produto_id\": 2, \"quantidade\": 1 }\n    ]\n}"
            }
          }
        },
        {
          "name": "T14 - Criar pedido RECUSADO via APP (POSITIVO - pagamento negado)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T14 | Status 201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.test('T14 | Status CANCELADO (pagamento recusado)', () => pm.expect(j.status).to.eql('CANCELADO'));",
                  "pm.test('T14 | canal_pedido = APP', () => pm.expect(j.canal_pedido).to.eql('APP'));",
                  "pm.test('T14 | Pagamento RECUSADO', () => pm.expect(j.pagamento.status).to.eql('RECUSADO'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_cliente}}" }
            ],
            "url": "{{base_url}}/pedidos",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"unidade_id\": 1,\n    \"canal_pedido\": \"APP\",\n    \"forma_pagamento\": \"MOCK\",\n    \"cenario_pagamento\": \"RECUSADO\",\n    \"itens\": [\n        { \"produto_id\": 1, \"quantidade\": 1 }\n    ]\n}"
            }
          }
        },
        {
          "name": "T15 - Criar pedido sem canal_pedido (NEGATIVO 422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T15 | Status 422', () => pm.response.to.have.status(422));",
                  "pm.test('T15 | Erro VALIDACAO_INVALIDA', () => {",
                  "    pm.expect(pm.response.json().error).to.eql('VALIDACAO_INVALIDA');",
                  "});",
                  "pm.test('T15 | Details menciona canal_pedido', () => {",
                  "    const details = JSON.stringify(pm.response.json().details);",
                  "    pm.expect(details).to.include('canal_pedido');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_cliente}}" }
            ],
            "url": "{{base_url}}/pedidos",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"unidade_id\": 1,\n    \"itens\": [\n        { \"produto_id\": 1, \"quantidade\": 1 }\n    ]\n}"
            }
          }
        },
        {
          "name": "T16 - Estoque insuficiente (NEGATIVO 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T16 | Status 409', () => pm.response.to.have.status(409));",
                  "pm.test('T16 | Erro ESTOQUE_INSUFICIENTE', () => {",
                  "    pm.expect(pm.response.json().error).to.eql('ESTOQUE_INSUFICIENTE');",
                  "});",
                  "pm.test('T16 | Tem details com disponível', () => {",
                  "    const details = JSON.stringify(pm.response.json().details);",
                  "    pm.expect(details).to.include('Disponível');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_cliente}}" }
            ],
            "url": "{{base_url}}/pedidos",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"unidade_id\": 2,\n    \"canal_pedido\": \"WEB\",\n    \"itens\": [\n        { \"produto_id\": 3, \"quantidade\": 1 }\n    ]\n}"
            }
          }
        },
        {
          "name": "T17 - Detalhar pedido (POSITIVO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T17 | Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('T17 | Tem pedido_id', () => pm.expect(j.pedido_id).to.be.a('number'));",
                  "pm.test('T17 | Tem itens', () => pm.expect(j.itens).to.be.an('array'));",
                  "pm.test('T17 | Tem pagamento', () => pm.expect(j.pagamento).to.be.an('object'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_cliente}}" }],
            "url": "{{base_url}}/pedidos/{{pedido_id}}"
          }
        },
        {
          "name": "T18 - Listar pedidos filtrado por canal (POSITIVO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T18 | Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('T18 | Tem data array', () => {",
                  "    pm.expect(pm.response.json().data).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "url": {
              "raw": "{{base_url}}/pedidos?canal_pedido=TOTEM",
              "query": [{ "key": "canal_pedido", "value": "TOTEM" }]
            }
          }
        },
        {
          "name": "T19 - Atualizar status para EM_PREPARO (POSITIVO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T19 | Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('T19 | Status EM_PREPARO', () => {",
                  "    pm.expect(pm.response.json().status_atual).to.eql('EM_PREPARO');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_cozinha}}" }
            ],
            "url": "{{base_url}}/pedidos/{{pedido_id}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"EM_PREPARO\"\n}"
            }
          }
        },
        {
          "name": "T20 - Transição de status inválida (NEGATIVO 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T20 | Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('T20 | Erro TRANSICAO_INVALIDA', () => {",
                  "    pm.expect(pm.response.json().error).to.eql('TRANSICAO_INVALIDA');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token_cozinha}}" }
            ],
            "url": "{{base_url}}/pedidos/{{pedido_id}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"AGUARDANDO_PAGAMENTO\"\n}"
